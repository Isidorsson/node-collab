{
  "name": "node-collab",
  "version": "0.1.0",
  "private": true,
  "description": "Express + Socket.IO + Redis pub/sub real-time service. Node twin of the Go collab-board.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:frontend": "npm --prefix frontend run start",
    "build": "npm run build:frontend && npm run build:backend",
    "build:backend": "tsc -p tsconfig.build.json",
    "build:frontend": "npm --prefix frontend ci && npm --prefix frontend run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "npm --prefix frontend run test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "bench": "tsx bench/load.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
